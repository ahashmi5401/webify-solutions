# Database
DATABASE_URL="postgresql://user:password@localhost:5432/webify_solutions?schema=public&sslmode=verify-full"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional - for Google login)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Resend Email
RESEND_API_KEY="re_xxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@webify-solutions.com"
RESEND_FROM_NAME="Webify Solutions"
ADMIN_EMAIL="admin@webify-solutions.com"

# Cloudinary (for image/video uploads)
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Upstash Redis (for rate limiting)
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# Cloudflare Turnstile (for CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your-turnstile-site-key"
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"

# Node Environment
NODE_ENV="development"

# Seed Script (optional - for custom admin password during seeding)
SEED_ADMIN_PASSWORD="your-custom-admin-password"
